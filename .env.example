# Nova V1 — Environment Configuration
# Copy to .env and fill in required values.
# Lines starting with # are comments. Uncomment to override defaults.

# ── Required ──────────────────────────────────────────────────────────────────
API_KEY=                          # Shared secret for API auth (auto-generated by install.sh)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=                         # Home Assistant Long-Lived Access Token

# ── LLM Provider ─────────────────────────────────────────────────────────────
# LLM_PROVIDER=ollama             # ollama | openai | google | anthropic
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
# OLLAMA_VISION_MODEL=llama3.2-vision:11b-instruct-q4_K_M
# OLLAMA_VISION_URL=              # Separate Ollama instance for vision (optional)
# OLLAMA_LOCAL_TEXT_MODEL=         # Override local text model selection
# PROACTIVE_OLLAMA_MODEL=         # Override proactive/fast local model
# GEMINI_API_KEYS=                # Comma-separated Gemini key pool for vision rotation
# CLOUD_MODEL=                    # Cloud model name (e.g. gemini-2.5-flash, gpt-4o-mini)

# ── Cloud API Keys (required only if LLM_PROVIDER != ollama) ─────────────────
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=

# ── STT / TTS ────────────────────────────────────────────────────────────────
# WHISPER_MODEL=small             # tiny | base | small | medium | large-v3
# TTS_PROVIDER=piper              # piper | afrotts | elevenlabs
# PIPER_VOICE=en_US-lessac-medium
# AFROTTS_VOICE=af_heart
# AFROTTS_SPEED=1.0
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_monolingual_v1

# ── Intron Afro TTS Sidecar ──────────────────────────────────────────────────
# INTRON_AFRO_TTS_URL=http://127.0.0.1:8021
# INTRON_AFRO_TTS_TIMEOUT_S=90.0
# INTRON_AFRO_TTS_REFERENCE_WAV=
# INTRON_AFRO_TTS_LANGUAGE=en

# ── Server ────────────────────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8001
# LOG_LEVEL=INFO
# PUBLIC_URL=                     # Public HTTPS URL for SSML audio (e.g. Cloudflare tunnel)
# CORS_ORIGINS=http://<YOUR_SERVER_IP>:8001

# ── Speakers ──────────────────────────────────────────────────────────────────
# SPEAKERS=                       # Comma-separated HA media_player entity IDs
# TTS_ENGINE=tts.google_translate_en_com
# SPEAKER_AUDIO_OFFSET_MS=0       # Delay browser audio to sync with room speakers

# ── Motion Clips ──────────────────────────────────────────────────────────────
# MOTION_CLIP_DURATION_S=8
# MOTION_CLIP_SEARCH_CANDIDATES=120
# MOTION_CLIP_SEARCH_RESULTS=24
# MOTION_CLIP_RETENTION_DAYS=30   # 0 = keep forever
# MOTION_VISION_PROVIDER=gemini   # gemini | ollama | ollama_remote
# SHARED_MEMORY_DB_PATH=          # Optional shared memory DB for cross-process context

# ── Proactive Service Cooldowns ───────────────────────────────────────────────
# PROACTIVE_ENTITY_COOLDOWN_S=600
# PROACTIVE_CAMERA_COOLDOWN_S=600
# PROACTIVE_CAMERA_CAPTURE_COOLDOWN_S=60
# PROACTIVE_GLOBAL_MOTION_COOLDOWN_S=600
# PROACTIVE_GLOBAL_ANNOUNCE_COOLDOWN_S=300
# PROACTIVE_QUEUE_DEDUP_COOLDOWN_S=120
# PROACTIVE_BATCH_WINDOW_S=60
# PROACTIVE_MAX_BATCH_CHANGES=20
# PROACTIVE_WEATHER_COOLDOWN_S=3600
# PROACTIVE_FORECAST_HOUR=7

# ── Heating ───────────────────────────────────────────────────────────────────
# HEATING_LLM_PROVIDER=gemini     # gemini | ollama
# HEATING_SHADOW_ENABLED=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# SESSION_RATE_LIMIT_MAX=30
# SESSION_RATE_LIMIT_WINDOW_S=60
# HA_POWER_ALERT_COOLDOWN_S=1800
# SENSOR_WATCH_OLLAMA_MODEL=      # Override local model used by sensor watch
# SENSOR_WATCH_REVIEW_TIMEOUT_S=120.0

# ── Music Assistant ───────────────────────────────────────────────────────────
# MUSIC_ASSISTANT_URL=http://localhost:8095

# ── Optional Features ────────────────────────────────────────────────────────
# SCOREBOARD_ENABLED=true            # Set false to disable family chore scoreboard

# ── Blue Iris (camera fallback when HA is down) ──────────────────────────────
# BLUEIRIS_URL=http://192.168.0.33:81

# ── CodeProject.AI (face recognition, YOLOv5, ALPR) ─────────────────────────
# CODEPROJECT_AI_URL=http://192.168.0.33:32168

# ── Home Assistant Local URL (skip TLS/DNS for internal calls) ───────────────
# HA_LOCAL_URL=https://192.168.0.154:8123
